<script>
function fmt(n){ return '$'+Math.round(n).toLocaleString(); }

function calculateCarLoan(){
  const price = parseFloat(document.getElementById('carPrice').value)||0;
  const down = parseFloat(document.getElementById('downPayment').value)||0;
  const tradeIn = parseFloat(document.getElementById('tradeIn').value)||0;
  const rate = parseFloat(document.getElementById('carRate').value)||0;
  const term = parseInt(document.getElementById('carTerm').value)||60;
  const tax = parseFloat(document.getElementById('salesTax').value)||0;

  const taxAmount = (price - tradeIn) * (tax/100);
  const loan = price - down - tradeIn + taxAmount;
  const monthlyRate = (rate/100)/12;
  
  let monthly;
  if(monthlyRate === 0){ monthly = loan/term; }
  else { monthly = loan * (monthlyRate * Math.pow(1+monthlyRate,term)) / (Math.pow(1+monthlyRate,term)-1); }
  
  const totalPaid = monthly * term;
  const totalInterest = totalPaid - loan;

  // Savings vs 84 months
  const r84 = monthlyRate;
  let m84;
  if(r84===0){ m84=loan/84; } else { m84=loan*(r84*Math.pow(1+r84,84))/(Math.pow(1+r84,84)-1); }
  const savings = (m84*84) - totalPaid;

  document.getElementById('monthlyPayment').textContent = fmt(monthly);
  document.getElementById('loanAmount').textContent = fmt(loan);
  document.getElementById('totalInterest').textContent = fmt(totalInterest);
  document.getElementById('totalCost').textContent = fmt(totalPaid + down + tradeIn);
  document.getElementById('savings').textContent = term < 84 ? fmt(savings) : '—';

  // Amortization by year
  let balance = loan;
  let tableHTML = '<tr><th>Year</th><th>Principal</th><th>Interest</th><th>Balance</th></tr>';
  let yearCount = Math.ceil(term/12);
  
  for(let y=1; y<=yearCount; y++){
    let months = y === yearCount ? term % 12 || 12 : 12;
    let yearPrincipal = 0, yearInterest = 0;
    for(let m=0; m<months; m++){
      let intPmt = balance * monthlyRate;
      let prinPmt = monthly - intPmt;
      yearInterest += intPmt;
      yearPrincipal += prinPmt;
      balance -= prinPmt;
    }
    tableHTML += `<tr>
      <td>Year ${y}</td>
      <td style="color:#44dd88">${fmt(yearPrincipal)}</td>
      <td style="color:#ff4444">${fmt(yearInterest)}</td>
      <td>${fmt(Math.max(0,balance))}</td>
    </tr>`;
  }
  document.getElementById('amortData').innerHTML = tableHTML;

  // SMART ALERT LOGIC
  const alert = document.getElementById('smartAlert');
  const saSub = document.getElementById('saSub');
  const saTitle = document.getElementById('saTitle');

  if(rate >= 10){
    saTitle.textContent = `⚠️ ${rate}% is a high car loan rate`;
    saSub.textContent = `You're paying ${fmt(totalInterest)} in interest. Buyers with similar profiles often qualify for rates 2-4% lower. A quick check won't affect your credit score.`;
    alert.style.display='block';
  } else if(totalInterest >= 3000){
    saTitle.textContent = `💡 You're paying ${fmt(totalInterest)} in interest`;
    saSub.textContent = `Even dropping your rate by 1.5% would save you ${fmt(totalInterest*0.25)}+. Takes 2 minutes to see if you qualify for better terms.`;
    alert.style.display='block';
  } else if(loan >= 30000){
    saTitle.textContent = `📊 Large loan — rate shopping is critical`;
    saSub.textContent = `On a ${fmt(loan)} loan, every 1% difference in rate = ${fmt(loan*0.01*term/12)} in extra interest. Always compare at least 3 lenders.`;
    alert.style.display='block';
  } else {
    alert.style.display='none';
  }

  // Store for copy
  window._carResults = { loan, rate, term, monthly, totalInterest, totalPaid: totalPaid+down+tradeIn };

  const results = document.getElementById('results');
  results.classList.add('show');
  results.scrollIntoView({behavior:'smooth', block:'nearest'});
}

function copyResults(){
  const r = window._carResults;
  if(!r) return;
  const text = `My Car Loan Results (via FinanceRateCalc.com)\n\nLoan Amount: $${Math.round(r.loan).toLocaleString()}\nInterest Rate: ${r.rate}%\nLoan Term: ${r.term} months\nMonthly Payment: $${Math.round(r.monthly).toLocaleString()}\nTotal Interest: $${Math.round(r.totalInterest).toLocaleString()}\nTotal Cost: $${Math.round(r.totalPaid).toLocaleString()}\n\nCalculated at financeratecalc.com/car-loan-calculator.html`;
  navigator.clipboard.writeText(text).then(()=>{
    const btn = document.getElementById('copyBtn');
    btn.textContent = '✅ Copied!';
    btn.classList.add('copied');
    setTimeout(()=>{ btn.textContent='📋 Copy My Results'; btn.classList.remove('copied'); }, 2500);
  });
}

// Auto calculate on load
calculateCarLoan();
</script>
